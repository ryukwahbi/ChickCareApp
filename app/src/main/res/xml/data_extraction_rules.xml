<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules xmlns:tools="http://schemas.android.com/tools">
    <cloud-backup>
        <exclude domain="sharedpref" path="two_factor_prefs.xml"
            tools:ignore="FullBackupContent" />
        <exclude domain="sharedpref" path="biometric_prefs.xml"
            tools:ignore="FullBackupContent" />
        <include domain="sharedpref" path="ChickCarePrefs.xml"/>
        <include domain="sharedpref" path="chickcare_settings.xml"/>
        <include domain="sharedpref" path="reminders.xml"/>
        <exclude domain="sharedpref" path="account_manager.xml"
            tools:ignore="FullBackupContent" />
        <include domain="file" path="."/>
        <include domain="database" path="."/>
    </cloud-backup>
    
    <device-transfer>
        <exclude domain="sharedpref" path="two_factor_prefs.xml"
            tools:ignore="FullBackupContent" />
        <exclude domain="sharedpref" path="biometric_prefs.xml"
            tools:ignore="FullBackupContent" />
        <exclude domain="sharedpref" path="account_manager.xml"
            tools:ignore="FullBackupContent" />
        <include domain="sharedpref" path="ChickCarePrefs.xml"/>
        <include domain="sharedpref" path="chickcare_settings.xml"/>
        <include domain="sharedpref" path="reminders.xml"/>
        <include domain="file" path="."/>
        <include domain="database" path="."/>
    </device-transfer>
</data-extraction-rules>